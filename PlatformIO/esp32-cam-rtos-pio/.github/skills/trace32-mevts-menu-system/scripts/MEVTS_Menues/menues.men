		popup "&View Memory Dump"
		(
			menuitem "IR&OM"
			(
				data.dump 0x10000000--0x1001ffff /Dialog
			)
			menuitem "&IRAM"
			(
				data.dump 0x20000000--0x203fffff /Dialog
			)
			menuitem "&DRAM"
			(
				data.dump 0x30000000--0x303fffff /Dialog
			)
		)
		
		popup "Save Memory Dump"
		(
			menuitem "IR&OM"
			(
				do ~~/demo/arm/MEVTS_Menues/Dumps/General/getDump.cmm  "irom0"
			)
			menuitem "&IRAM"
			(
				do ~~/demo/arm/MEVTS_Menues/Dumps/General/getDump.cmm "iram0" 
			)
			menuitem "&DRAM"
			(
				do ~~/demo/arm/MEVTS_Menues/Dumps/General/getDump.cmm "dram0" 
			)	
	)
   )
)
